# ─── Google Sheets API ───────────────────────────────────────────────────────

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=XXX-XXX-XXX

# Default sheet range in A1 notation Success Criteria!B11:P20
# By default if no range is provided the app will search for the table containing following columns
# "Category" "Requirement" "Priority" "Method" "Met" "Date" "Validated" "Validated By" "Grafana Comments" "Comments"
RANGE=

# Path to your service account key file
GOOGLE_KEY_FILE=service-account.json

# Server port (optional, default: 8080)
PORT=8080

# ─── Grafana Cloud Provisioning (setup-grafana-cloud.sh) ─────────────────────

# Cloud Access Policy token — create at grafana.com → Security → Access Policies
# Required scopes: dashboards:read, dashboards:write, datasources:read, datasources:write, pdc:read, pdc:write
GRAFANA_CLOUD_ACCESS_POLICY_TOKEN=

# Stack subdomain — for https://myorg.grafana.net the slug is "myorg"
GRAFANA_STACK_SLUG=

# Numeric stack ID — visible in grafana.com/orgs/<org>/stacks
GRAFANA_STACK_ID=

# Full URL of your Grafana Cloud stack
GRAFANA_STACK_URL=https://<slug>.grafana.net

# Grafana Cloud cluster the stack runs on (e.g. prod-us-east-0, prod-eu-west-2)
# Visible in the stack details on grafana.com
GRAFANA_CLUSTER=prod-eu-west-2

# PDC network name — used to identify the Private Data Source Connect network
PDC_NETWORK_NAME=pov-pdc

# Infinity datasource name shown in Grafana
DATASOURCE_NAME=pov-success

# URL where the gsheets-api container is reachable (Docker bridge IP, as in README)
GSHEETS_API_URL=http://172.17.0.1:8080
